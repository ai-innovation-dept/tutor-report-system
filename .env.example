DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/tutor
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8
# === メール送信(SMTP) ===
# 開発: MailHog（認証/TLSなし）。本番: 外部SMTPサービスのホスト/ポート/認証情報に差し替えるだけで切替可能。
# 送信経路(HOST/PORT/USERNAME/PASSWORD/TLS)は両システム共通。送信元(From)のみシステム別に分離。
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
# TLS方式: none(開発/MailHog) / starttls(通常587番) / ssl(暗黙TLS・通常465番)
SMTP_TLS=none
# 送信元アドレス（仮。本番で実際の送信元に変更）。指導実績報告システム(backend)用。
SMTP_FROM=noreply@example.com
# 業務連絡表システム(new_backend)用の送信元（仮）。旧システムと分けたい場合に使用（同値でも可）。
NEW_SMTP_FROM=noreply@work-system.local
# === メール送信キュー（バースト送信によるスパム判定/ロック対策） ===
# メールは即時送信せず送信キュー(アウトボックス)へ投函し、バックグラウンドのドレイナが
# 「1通ずつ・下記間隔をあけて」順次送信する。同時送信・短時間連打を防ぐ。
# MAIL_BACKEND: smtp=実送信（本番・開発MailHog） / console=ログ出力のみ（テスト/CI。実送信しない）。
MAIL_BACKEND=console
# 1通ごとの送信間隔（秒）。フリーメール等の連打ロックを避ける安全側の既定。
MAIL_SEND_INTERVAL_SECONDS=4
# 1回のドレイン実行で送る最大通数 / 送信失敗時の最大試行回数。
MAIL_OUTBOX_BATCH_MAX=20
MAIL_MAX_ATTEMPTS=5
#
# --- メール送信モードの簡易切替（mailmode.sh 用） ---
# `bash mailmode.sh sandbox|off|live` が下記グループを読み、SMTP_*/MAIL_BACKEND を切り替えて再起動する。
# アプリ本体は SMTP_*/MAIL_BACKEND だけを見るため、ここの値は mailmode.sh からのみ参照される（アプリは無視）。
#   sandbox = 検証（Mailtrapサンドボックス：実ユーザーに届かず全て捕捉）
#   off     = 送信しない（ログのみ）
#   live    = 実配信（Brevo等）
# 検証用 Mailtrap サンドボックス（実値はサーバーの .env に設定。From は何でも可のため不要）
MAIL_SANDBOX_HOST=sandbox.smtp.mailtrap.io
MAIL_SANDBOX_PORT=587
MAIL_SANDBOX_TLS=starttls
MAIL_SANDBOX_USERNAME=
MAIL_SANDBOX_PASSWORD=
# 実配信（Brevo 等。FROM は認証済み送信者アドレス）
MAIL_LIVE_HOST=smtp-relay.brevo.com
MAIL_LIVE_PORT=587
MAIL_LIVE_TLS=starttls
MAIL_LIVE_USERNAME=
MAIL_LIVE_PASSWORD=
MAIL_LIVE_FROM=
#
# --- 本番(外部SMTPサービス)の設定例：上記を以下のように差し替える ---
# SMTP_HOST=smtp.your-provider.example      # 例: SendGrid/SES/Google Workspace/さくら等のSMTPホスト
# SMTP_PORT=587
# SMTP_USERNAME=your-smtp-user-or-apikey
# SMTP_PASSWORD=your-smtp-password
# SMTP_TLS=starttls                          # 465番のサービスなら ssl
# SMTP_FROM=no-reply@yourdomain.co.jp
# NEW_SMTP_FROM=no-reply@yourdomain.co.jp
#
# --- 例: Gmail (smtp.gmail.com) で送る場合（最短。2段階認証＋アプリパスワードが必須） ---
#   Google アカウント → セキュリティ → 2段階認証process を有効化 → 「アプリ パスワード」を発行し
#   その16桁を SMTP_PASSWORD に設定（通常のログインパスワードでは送信できない）。
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=kintaikanri.tutor1@gmail.com
# SMTP_PASSWORD=xxxxxxxxxxxxxxxx            # アプリパスワード16桁（スペース無し）
# SMTP_TLS=starttls
# SMTP_FROM=kintaikanri.tutor1@gmail.com
# NEW_SMTP_FROM=kintaikanri.tutor1@gmail.com
#
# --- 例: AWS SES で送る場合（本番運用向け） ---
#   SESコンソール →「SMTP設定」→「SMTP認証情報の作成」でSMTPユーザー名/パスワードを発行
#   （IAMのアクセスキーとは別物）。送信元(From)はSESで検証済みのドメイン/アドレスにする。
#   サンドボックス中は検証済み宛先にしか送れない→任意宛先に送るには本番アクセス申請が必要。
#   ホストは利用リージョンに合わせる（東京=ap-northeast-1）。
# SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USERNAME=（SESで発行したSMTPユーザー名）
# SMTP_PASSWORD=（SESで発行したSMTPパスワード）
# SMTP_TLS=starttls
# SMTP_FROM=no-reply@yourdomain.co.jp
# NEW_SMTP_FROM=no-reply@yourdomain.co.jp
# 指導実績報告システム（既存システム / backend, port 8000）の公開URL
BASE_URL=http://localhost:8000
# 業務連絡表システム（新システム / new_backend, port 8001）の公開URL
NEW_BASE_URL=http://localhost:8001
REMINDER_DAYS_BEFORE_MONTH_END=3
# === 【既存システム】提出締切通知（講師向け・改修依頼 202607161428） ===
# 提出締切 = 対象月の翌月第一営業日（土日・祝日・下記休業日を除く）。
# 通知は 1回目=月中（下記N日・画面バナー＋メール）/ 2回目=締切前日（バナーは至急表示に切替＋メール）。
# メール送信の有効化フラグ。誤送信防止のため既定は無効（画面バナーは常時表示される）。
# 本番で有効化する場合のみ true を設定する。
DEADLINE_NOTICE_ENABLED=false
# 1回目（月中）通知の開始日（毎月N日）
DEADLINE_NOTICE_MIDMONTH_DAY=15
# 営業日判定で休業扱いにする日（MM-DD カンマ区切り・毎年適用）。土日祝は自動判定のため会社独自の休業日のみ。
BUSINESS_CLOSED_DAYS=12-29,12-30,12-31,01-01,01-02,01-03
TIMEZONE=Asia/Tokyo
CORS_ORIGINS=
AUTO_CREATE_TABLES=false
ENVIRONMENT=development
