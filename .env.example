DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/tutor
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8
# === メール送信(SMTP) ===
# 開発: MailHog（認証/TLSなし）。本番: 外部SMTPサービスのホスト/ポート/認証情報に差し替えるだけで切替可能。
# 送信経路(HOST/PORT/USERNAME/PASSWORD/TLS)は両システム共通。送信元(From)のみシステム別に分離。
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
# TLS方式: none(開発/MailHog) / starttls(通常587番) / ssl(暗黙TLS・通常465番)
SMTP_TLS=none
# 送信元アドレス（仮。本番で実際の送信元に変更）。指導実績報告システム(backend)用。
SMTP_FROM=noreply@example.com
# 業務連絡表システム(new_backend)用の送信元（仮）。旧システムと分けたい場合に使用（同値でも可）。
NEW_SMTP_FROM=noreply@work-system.local
#
# --- 本番(外部SMTPサービス)の設定例：上記を以下のように差し替える ---
# SMTP_HOST=smtp.your-provider.example      # 例: SendGrid/SES/Google Workspace/さくら等のSMTPホスト
# SMTP_PORT=587
# SMTP_USERNAME=your-smtp-user-or-apikey
# SMTP_PASSWORD=your-smtp-password
# SMTP_TLS=starttls                          # 465番のサービスなら ssl
# SMTP_FROM=no-reply@yourdomain.co.jp
# NEW_SMTP_FROM=no-reply@yourdomain.co.jp
# 指導実績報告システム（既存システム / backend, port 8000）の公開URL
BASE_URL=http://localhost:8000
# 業務連絡表システム（新システム / new_backend, port 8001）の公開URL
NEW_BASE_URL=http://localhost:8001
REMINDER_DAYS_BEFORE_MONTH_END=3
TIMEZONE=Asia/Tokyo
CORS_ORIGINS=
AUTO_CREATE_TABLES=false
ENVIRONMENT=development
