# 指導実績報告システム（既存システム / backend, port 8000）の公開URL
BASE_URL=http://localhost:8000
# 業務連絡表システム（新システム / new_backend, port 8001）の公開URL
NEW_BASE_URL=http://localhost:8001
REMINDER_DAYS_BEFORE_MONTH_END=3
TIMEZONE=Asia/Tokyo
CORS_ORIGINS=
AUTO_CREATE_TABLES=false
ENVIRONMENT=development
